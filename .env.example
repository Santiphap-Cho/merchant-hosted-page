# Ports (single source of truth)
API_PORT=3009
WEB_PORT=5177

# API — CORS must match the web origin (derived from WEB_PORT if omitted)
CORS_ORIGIN=https://localhost:5177

# Frontend — optional; defaults to http://localhost:${API_PORT}
# VITE_API_URL=http://localhost:3009

# PayGenix
PAYGENIX_API_URL=https://dev-api.paygenix.co
PAYGENIX_SECRET_KEY=your_secret_key_here
PAYGENIX_SERVICE_ID=1001
MERCHANT_URL=https://localhost:5177
WEB_HTTPS=true
# PayGenix requires https callback_url — auto-upgraded from MERCHANT_URL if omitted
# Use your ngrok/tunnel URL for local payment return testing, e.g. https://abc123.ngrok.io
# PAYGENIX_CALLBACK_URL=https://abc123.ngrok.io

# Vercel (set in each project's Environment Variables dashboard)
# Web project: VITE_API_URL=https://your-api.vercel.app
# API project: CORS_ORIGIN, MERCHANT_URL, PAYGENIX_* (see README)
